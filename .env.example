# Salin file ini menjadi .env lalu isi nilainya.

# Database (SQLite lama dinonaktifkan)
# DATABASE_URL="file:./dev.db"

# Database Supabase (Untuk pengembangan lokal & migrasi, gunakan Session Mode port 5432)
# Salin dari Settings -> Database -> Connection String -> URI -> Pilih Session Mode
# Catatan: Saat deploy di Vercel, ubah DATABASE_URL di dashboard Vercel ke Transaction Mode (port 6543)
DATABASE_URL="postgresql://postgres.[REF_ID]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Google Gemini API Key (ambil gratis di https://aistudio.google.com/apikey)
GEMINI_API_KEY="your-gemini-api-key"

# Model Gemini yang dipakai (2.5-flash mendukung free tier; 2.0 sudah limit: 0)
GEMINI_MODEL="gemini-2.5-flash"

# Rahasia untuk menandatangani sesi login (JWT). Wajib diisi.
# Buat dengan: openssl rand -base64 32
SESSION_SECRET="ganti-dengan-string-acak-minimal-32-karakter"
